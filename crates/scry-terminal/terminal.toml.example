# Scry Terminal — Example Configuration
# 
# Copy this file to ~/.config/scry/terminal.toml and customize as needed.
# All fields are optional; the defaults shown here are used if a field is omitted.
#
# Hot-reload: the config is read once at startup. Restart scry-terminal to
# pick up changes. Ctrl+= / Ctrl+- / Ctrl+0 zoom changes are saved live.

# ── Shell ──────────────────────────────────────────────────────────────────────
# Defaults to $SHELL, then /bin/sh if $SHELL is unset.
# shell = "/bin/zsh"

# ── Font ──────────────────────────────────────────────────────────────────────
[font]
# Font family for system font lookup.
family = "monospace"

# Absolute path to a TTF/OTF file (overrides family lookup).
# path = "/usr/share/fonts/JetBrainsMono-Regular.ttf"

# Font size in pixels.
size = 14.0

# Bold/italic family overrides. Leave empty to derive from `family`.
bold_family   = ""
italic_family = ""

# Line height multiplier. 1.0 = tight (default). 1.2 = comfortable.
line_height = 1.0

# Enable OpenType ligature substitution (requires a ligature-capable font).
# Planned feature — set true now to opt in when support lands.
ligatures = false

# ── Colors ────────────────────────────────────────────────────────────────────
[colors]
# Default foreground / background in #RRGGBB.
foreground = "#c0caf5"
background = "#1a1b26"

# 16 ANSI palette entries (index 0–15):
# 0-7: normal black/red/green/yellow/blue/magenta/cyan/white
# 8-15: bright variants
palette = [
    "#15161e", "#f7768e", "#9ece6a", "#e0af68",
    "#7aa2f7", "#bb9af7", "#7dcfff", "#a9b1d6",
    "#414868", "#f7768e", "#9ece6a", "#e0af68",
    "#7aa2f7", "#bb9af7", "#7dcfff", "#c0caf5",
]

# ── Cursor ────────────────────────────────────────────────────────────────────
[cursor]
# Cursor shape: "block" | "bar" | "underline"
style = "block"

# Whether the cursor blinks.
# Per-application overrides via DECSCUSR (e.g. from neovim) take precedence
# at runtime; this is the initial value when the terminal starts.
blink = true

# Half-period of the blink cycle in milliseconds.
# Total visible+hidden cycle = blink_rate_ms × 2.
# 530 ms → ~0.94 Hz (typical for most terminals).
# Decrease for a faster blink, increase for a slower one.
blink_rate_ms = 530

# Pixel thickness for "bar" and "underline" styles. Ignored for "block".
thickness = 2

# Fill opacity (0.0 = invisible, 1.0 = fully opaque).
opacity = 1.0

# Cursor color in #RRGGBB. Defaults to the foreground color.
# color = "#ffff00"

# ── Scrollback ────────────────────────────────────────────────────────────────
[scrollback]
# Maximum lines to retain in the scrollback buffer.
lines = 5000

# ── Window ────────────────────────────────────────────────────────────────────
[window]
# Initial terminal size in cells.
columns = 80
rows    = 24

# Padding around the terminal content in pixels.
padding = 6.0

# Subtle top-to-bottom darkening gradient (uses scry-engine GPU pipeline).
background_gradient = false

# Scrollbar visibility: "none" | "thin" | "overlay"
scrollbar = "none"

# Background alpha (0.0 = fully transparent, 1.0 = fully opaque).
# Compositor support required for values below 1.0.
opacity = 1.0

# Window title template. {title} is replaced with the application-set title
# (OSC 0/2). Leave as "{title}" for default behaviour.
title_format = "{title}"

# Ask before closing a window that has a running child process.
confirm_close = false

# ── Bell ──────────────────────────────────────────────────────────────────────
[bell]
# Master on/off switch. When false, BEL (0x07) is silently ignored.
enabled = true

# Flash the screen briefly on BEL.
visual = false

# Duration of the visual flash in milliseconds.
flash_duration_ms = 120

# Emit a system audio beep on BEL. Requires PulseAudio or equivalent.
audio = false

# ── Performance ───────────────────────────────────────────────────────────────
[performance]
# Maximum frames per second. 0 = vsync-limited (Fifo present mode).
# Lower values reduce battery usage; 60 is a sensible default.
fps_cap = 60

# Keep the render loop spinning even when the PTY is idle.
# Useful for overlays or animations that update independently of shell output.
render_on_idle = false

# ── Keybinds (scaffold — not yet dispatched) ──────────────────────────────────
# Override built-in key bindings. Format: "modifier+key" (e.g. "ctrl+c").
# An empty string means "use the built-in default".
[keybinds]
copy       = ""   # default: Ctrl+Shift+C
paste      = ""   # default: Ctrl+Shift+V
zoom_in    = ""   # default: Ctrl+=
zoom_out   = ""   # default: Ctrl+-
zoom_reset = ""   # default: Ctrl+0
scroll_up  = ""   # default: Shift+PageUp
scroll_down = ""  # default: Shift+PageDown
